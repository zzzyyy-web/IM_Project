{
  "name": "im-desktop-client",
  "version": "1.0.0",
  "private": true,
  "description": "IM desktop client wrapper",
  "main": "src/main.js",
  "scripts": {
    "copy-web": "node scripts/copy-web.js",
    "start": "npm run copy-web && electron .",
    "pack": "npm run copy-web && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.im.project.desktop",
    "productName": "IM Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "web-dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "IM-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^38.5.0",
    "electron-builder": "^26.0.12",
    "fs-extra": "^11.3.2"
  }
}
